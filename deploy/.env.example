# n8n deploy — скопируй в .env и заполни нужные значения.
# Все переменные здесь — глобальные переменные окружения (контейнера/хоста).
# Для деплоя без S3 достаточно оставить дефолты или задать только свои переменные.

# ========== Глобальные переменные (окружение) ==========

# --- S3: загрузка доп. .env при старте контейнера (опционально) ---
# Задаются в .env или в окружении хоста. Entrypoint подтягивает файл из S3 и применяет переменные до запуска n8n.
# S3_ENV_URI — S3 URI объекта в формате s3://<bucket>/<key>. У нас: папка env/, файл @n8n.env.
# S3_ENV_URI=s3://my-bucket/env/@n8n.env
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-west-1

# --- База данных (по умолчанию SQLite, переменные не нужны) ---
# DB_TYPE=sqlite
# DB_SQLITE_DATABASE=database.sqlite

# PostgreSQL (раскомментируй и заполни, если используешь внешнюю БД)
# DB_TYPE=postgresdb
# DB_POSTGRESDB_HOST=localhost
# DB_POSTGRESDB_PORT=5432
# DB_POSTGRESDB_DATABASE=n8n
# DB_POSTGRESDB_USER=postgres
# DB_POSTGRESDB_PASSWORD=
# DB_POSTGRESDB_SCHEMA=public

# --- n8n: данные и шифрование ---
# N8N_USER_FOLDER=/home/node/.n8n
# N8N_ENCRYPTION_KEY=

# --- n8n: URL и порт (для webhook, письм и т.д.) ---
# N8N_HOST=localhost
# N8N_PORT=5678
# N8N_PROTOCOL=http
# N8N_PATH=/

# --- Прочее ---
# GENERIC_TIMEZONE=Europe/Moscow
